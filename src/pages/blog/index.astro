---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import GradientBackground from '@/components/GradientBackground.astro'
import Heading from '@/components/Heading.astro'
import Subheading from '@/components/Subheading.astro'
import Lead from '@/components/Lead.astro'
import Button from '@/components/Button.astro'
import Footer from '@/components/Footer.astro'
import { Navbar } from '@/components/react/Navbar'
import { getFeaturedPosts, getPosts, getCategories, getPostsCount } from '@/lib/blog'
import dayjs from 'dayjs'

const featuredPosts = await getFeaturedPosts(3)
const posts = await getPosts(0, 20)
const categories = await getCategories()
---
<BaseLayout title="Blog" description="Stay informed with product updates, company news, and insights on how to sell smarter at your company.">
  <main class="overflow-hidden">
    <GradientBackground />
    <Container>
      <Navbar client:load />
      <Subheading class="mt-16">Blog</Subheading>
      <Heading as="h1" class="mt-2">What's happening at Slackwater.</Heading>
      <Lead class="mt-6 max-w-3xl">
        Stay informed with product updates, company news, and insights on how
        to sell smarter at your company.
      </Lead>
    </Container>
    {featuredPosts.length > 0 && (
      <div class="mt-16 bg-linear-to-t from-gray-100 pb-14">
        <Container>
          <h2 class="text-2xl font-medium tracking-tight">Featured</h2>
          <div class="mt-6 grid grid-cols-1 gap-8 lg:grid-cols-3">
            {featuredPosts.map((post) => (
              <div class="relative flex flex-col rounded-3xl bg-white p-2 ring-1 shadow-md shadow-black/5 ring-black/5">
                {post.data.mainImage && (
                  <img
                    alt={post.data.mainImage.alt || ''}
                    src={post.data.mainImage.src}
                    class="aspect-3/2 w-full rounded-2xl object-cover"
                  />
                )}
                <div class="flex flex-1 flex-col p-8">
                  <div class="text-sm/5 text-gray-700">
                    {dayjs(post.data.publishedAt).format('dddd, MMMM D, YYYY')}
                  </div>
                  <div class="mt-2 text-base/7 font-medium">
                    <a href={`/blog/${post.slug}`}>
                      <span class="absolute inset-0" />
                      {post.data.title}
                    </a>
                  </div>
                  <div class="mt-2 flex-1 text-sm/6 text-gray-500">
                    {post.data.excerpt}
                  </div>
                  {post.data.author && (
                    <div class="mt-6 flex items-center gap-3">
                      {post.data.author.image && (
                        <img
                          alt=""
                          src={post.data.author.image}
                          class="aspect-square size-6 rounded-full object-cover"
                        />
                      )}
                      <div class="text-sm/5 text-gray-700">
                        {post.data.author.name}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </Container>
      </div>
    )}
    <Container class="mt-16 pb-24">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div class="font-medium">All categories</div>
        <Button variant="outline" href="/blog/feed.xml" class="gap-1">
          <svg viewBox="0 0 16 16" fill="currentColor" class="size-4">
            <path d="M2.002 2.725a.75.75 0 0 1 .797-.699C8.79 2.42 13.58 7.21 13.974 13.201a.75.75 0 0 1-1.497.098C12.145 8.072 7.928 3.855 2.701 3.523a.75.75 0 0 1-.699-.798ZM2 8.75a.75.75 0 0 1 .75-.75c2.903 0 5.25 2.347 5.25 5.25a.75.75 0 0 1-1.5 0A3.75 3.75 0 0 0 2.75 9.5.75.75 0 0 1 2 8.75ZM3.5 14a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
          </svg>
          RSS Feed
        </Button>
      </div>
      {posts.length === 0 ? (
        <p class="mt-6 text-gray-500">No posts found.</p>
      ) : (
        <div class="mt-6">
          {posts.map((post) => (
            <div class="relative grid grid-cols-1 border-b border-b-gray-100 py-10 first:border-t first:border-t-gray-200 max-sm:gap-3 sm:grid-cols-3">
              <div>
                <div class="text-sm/5 max-sm:text-gray-700 sm:font-medium">
                  {dayjs(post.data.publishedAt).format('dddd, MMMM D, YYYY')}
                </div>
                {post.data.author && (
                  <div class="mt-2.5 flex items-center gap-3">
                    {post.data.author.image && (
                      <img
                        alt=""
                        src={post.data.author.image}
                        class="aspect-square size-6 rounded-full object-cover"
                      />
                    )}
                    <div class="text-sm/5 text-gray-700">
                      {post.data.author.name}
                    </div>
                  </div>
                )}
              </div>
              <div class="sm:col-span-2 sm:max-w-2xl">
                <h2 class="text-sm/5 font-medium">{post.data.title}</h2>
                <p class="mt-3 text-sm/6 text-gray-500">{post.data.excerpt}</p>
                <div class="mt-4">
                  <a href={`/blog/${post.slug}`} class="flex items-center gap-1 text-sm/5 font-medium">
                    <span class="absolute inset-0" />
                    Read more
                    <svg viewBox="0 0 16 16" fill="currentColor" class="size-4 fill-gray-400">
                      <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </Container>
    <Footer />
  </main>
</BaseLayout>
