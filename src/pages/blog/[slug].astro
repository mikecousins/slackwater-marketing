---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import GradientBackground from '@/components/GradientBackground.astro'
import Heading from '@/components/Heading.astro'
import Subheading from '@/components/Subheading.astro'
import Button from '@/components/Button.astro'
import Footer from '@/components/Footer.astro'
import { Navbar } from '@/components/react/Navbar'
import { getCollection } from 'astro:content'
import dayjs from 'dayjs'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await post.render()
---
<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <main class="overflow-hidden">
    <GradientBackground />
    <Container>
      <Navbar client:load />
      <Subheading class="mt-16">
        {dayjs(post.data.publishedAt).format('dddd, MMMM D, YYYY')}
      </Subheading>
      <Heading as="h1" class="mt-2">{post.data.title}</Heading>
      <div class="mt-16 grid grid-cols-1 gap-8 pb-24 lg:grid-cols-[15rem_1fr] xl:grid-cols-[15rem_1fr_15rem]">
        <div class="flex flex-wrap items-center gap-8 max-lg:justify-between lg:flex-col lg:items-start">
          {post.data.author && (
            <div class="flex items-center gap-3">
              {post.data.author.image && (
                <img
                  alt=""
                  src={post.data.author.image}
                  class="aspect-square size-6 rounded-full object-cover"
                />
              )}
              <div class="text-sm/5 text-gray-700">{post.data.author.name}</div>
            </div>
          )}
          {post.data.category && (
            <div class="flex flex-wrap gap-2">
              <a
                href="/blog"
                class="rounded-full border border-dotted border-gray-300 bg-gray-50 px-2 text-sm/6 font-medium text-gray-500"
              >
                {post.data.category.title}
              </a>
            </div>
          )}
        </div>
        <div class="text-gray-700">
          <div class="max-w-2xl xl:mx-auto">
            {post.data.mainImage && (
              <img
                alt={post.data.mainImage.alt || ''}
                src={post.data.mainImage.src}
                class="mb-10 aspect-3/2 w-full rounded-2xl object-cover shadow-xl"
              />
            )}
            <div class="prose prose-gray max-w-none [&>p]:my-10 [&>p]:text-base/8 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0 [&>h2]:mt-12 [&>h2]:mb-10 [&>h2]:text-2xl/8 [&>h2]:font-medium [&>h2]:tracking-tight [&>h2]:text-gray-950 [&>h3]:mt-12 [&>h3]:mb-10 [&>h3]:text-xl/8 [&>h3]:font-medium [&>h3]:tracking-tight [&>h3]:text-gray-950 [&>blockquote]:my-10 [&>blockquote]:border-l-2 [&>blockquote]:border-l-gray-300 [&>blockquote]:pl-6 [&>blockquote]:text-base/8 [&>blockquote]:text-gray-950 [&_strong]:font-semibold [&_strong]:text-gray-950 [&_a]:font-medium [&_a]:text-gray-950 [&_a]:underline [&_a]:decoration-gray-400 [&_a]:underline-offset-4 hover:[&_a]:decoration-gray-600 [&_ul]:list-disc [&_ul]:pl-4 [&_ul]:text-base/8 [&_ol]:list-decimal [&_ol]:pl-4 [&_ol]:text-base/8 [&_li]:my-2 [&_li]:pl-2">
              <Content />
            </div>
            <div class="mt-10">
              <Button variant="outline" href="/blog">
                <svg viewBox="0 0 16 16" fill="currentColor" class="size-4">
                  <path fill-rule="evenodd" d="M9.78 11.78a.75.75 0 0 1-1.06 0L5.47 8.53a.75.75 0 0 1 0-1.06l3.25-3.25a.75.75 0 1 1 1.06 1.06L7.06 8l2.72 2.72a.75.75 0 0 1 0 1.06Z" clip-rule="evenodd" />
                </svg>
                Back to blog
              </Button>
            </div>
          </div>
        </div>
      </div>
    </Container>
    <Footer />
  </main>
</BaseLayout>
