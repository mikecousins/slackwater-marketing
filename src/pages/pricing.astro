---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Gradient from '@/components/Gradient.astro'
import GradientBackground from '@/components/GradientBackground.astro'
import Heading from '@/components/Heading.astro'
import Subheading from '@/components/Subheading.astro'
import Lead from '@/components/Lead.astro'
import Button from '@/components/Button.astro'
import Footer from '@/components/Footer.astro'
import { Navbar } from '@/components/react/Navbar'
import { PricingTable } from '@/components/react/PricingTable'

const tiers = [
  {
    name: 'Starter',
    slug: 'starter',
    description: 'Everything you need to get started.',
    priceAnnual: 0,
    priceMonthly: 0,
    href: 'https://app.slackwater.ca',
    highlights: [
      { description: 'Retirement projections' },
      { description: 'Basic financial plan' },
      { description: 'Progress tracking' },
      { description: 'Basic withdrawal strategies' },
      { description: 'Advanced withdrawal strategies', disabled: true },
      { description: 'Fully optimized withdrawal plan', disabled: true },
    ],
  },
  {
    name: 'Pro',
    slug: 'pro',
    description: 'Unlock advanced strategies that could save you ~$200K in taxes.',
    priceAnnual: 50,
    priceMonthly: 4,
    href: 'https://app.slackwater.ca',
    highlights: [
      { description: 'Retirement projections' },
      { description: 'Detailed financial plan' },
      { description: 'Progress tracking' },
      { description: 'Basic withdrawal strategies' },
      { description: 'Advanced withdrawal strategies' },
      { description: 'Fully optimized withdrawal plan', disabled: true },
    ],
  },
  {
    name: 'Smart',
    slug: 'smart',
    description: 'The ultimate plan — could save you $500K to $1M+ in taxes.',
    priceAnnual: 200,
    priceMonthly: 17,
    href: 'https://app.slackwater.ca',
    highlights: [
      { description: 'Retirement projections' },
      { description: 'Detailed financial plan' },
      { description: 'Progress tracking' },
      { description: 'Basic withdrawal strategies' },
      { description: 'Advanced withdrawal strategies' },
      { description: 'Fully optimized withdrawal plan' },
    ],
  },
]
---
<BaseLayout title="Pricing" description="Choose the Slackwater plan that fits your retirement goals. Start free and upgrade when you're ready to optimize.">
  <main class="overflow-hidden">
    <GradientBackground />
    <Container>
      <Navbar client:load />
    </Container>
    <Container class="mt-16">
      <Heading as="h1">Choose your plan, see your future.</Heading>
      <Lead class="mt-6 max-w-3xl">
        Gain clarity into what your future looks like. Then we can build
        your dream retirement together.
      </Lead>
    </Container>
    <div class="relative py-24">
      <Gradient class="absolute inset-x-2 top-48 bottom-0 rounded-4xl ring-1 ring-black/5 ring-inset" />
      <Container class="relative">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
          {tiers.map((tier) => (
            <div class="-m-2 grid grid-cols-1 rounded-4xl ring-1 shadow-[inset_0_0_2px_1px_#ffffff4d] ring-black/5 max-lg:mx-auto max-lg:w-full max-lg:max-w-md">
              <div class="grid grid-cols-1 rounded-4xl p-2 shadow-md shadow-black/5">
                <div class="rounded-3xl bg-white p-10 pb-9 ring-1 shadow-2xl ring-black/5">
                  <Subheading>{tier.name}</Subheading>
                  <p class="mt-2 text-sm/6 text-gray-950/75">{tier.description}</p>
                  <div class="mt-8 flex items-center gap-4">
                    <div class="text-5xl font-medium text-gray-950">${tier.priceAnnual}</div>
                    <div class="text-sm/5 text-gray-950/75">
                      <p>CAD</p>
                      <p>per year</p>
                    </div>
                  </div>
                  {tier.priceMonthly > 0 && (
                    <p class="mt-2 text-sm/6 text-gray-950/50">That's just ${tier.priceMonthly}/month</p>
                  )}
                  <div class="mt-8">
                    <Button href={tier.href}>Get started</Button>
                  </div>
                  <div class="mt-8">
                    <h3 class="text-sm/6 font-medium text-gray-950">Maximize your retirement with:</h3>
                    <ul class="mt-3 space-y-3">
                      {tier.highlights.map((feature) => (
                        <li
                          data-disabled={feature.disabled ? true : undefined}
                          class="flex items-start gap-4 text-sm/6 text-gray-950/75 data-disabled:text-gray-950/25"
                        >
                          <span class="inline-flex h-6 items-center">
                            <svg viewBox="0 0 15 15" aria-hidden="true" class="size-[0.9375rem] shrink-0 fill-gray-950/25">
                              <path clip-rule="evenodd" d="M8 0H7v7H0v1h7v7h1V8h7V7H8V0z" />
                            </svg>
                          </span>
                          {feature.disabled && <span class="sr-only">Not included:</span>}
                          {feature.description}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </div>
    <PricingTable client:load />
    <div class="mx-2 my-24 rounded-4xl bg-gray-900 bg-[url(/dot-texture.svg)] pt-72 pb-24 lg:pt-36">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-[384px_1fr_1fr]">
          <div class="-mt-96 lg:-mt-52">
            <div class="-m-2 rounded-4xl bg-white/15 ring-1 shadow-[inset_0_0_2px_1px_#ffffff4d] ring-black/5 max-lg:mx-auto max-lg:max-w-xs">
              <div class="rounded-4xl p-2 shadow-md shadow-black/5">
                <div class="overflow-hidden rounded-3xl shadow-2xl outline outline-1 -outline-offset-1 outline-black/10">
                  <img alt="" src="/testimonials/tina-yards.jpg" class="aspect-3/4 w-full object-cover" />
                </div>
              </div>
            </div>
          </div>
          <div class="flex max-lg:mt-16 lg:col-span-2 lg:px-16">
            <figure class="mx-auto flex max-w-xl flex-col gap-16 max-lg:text-center">
              <blockquote>
                <p class="relative text-3xl tracking-tight text-white before:absolute before:-translate-x-full before:content-['\201C'] after:absolute after:content-['\201D'] lg:text-4xl">
                  Slackwater showed me exactly how to withdraw from my accounts in the
                  most tax-efficient way. I had no idea I was leaving so much money on
                  the table.
                </p>
              </blockquote>
              <figcaption class="mt-auto">
                <p class="text-sm/6 font-medium text-white">Sarah Mitchell</p>
                <p class="text-sm/6 font-medium">
                  <span class="bg-linear-to-r from-[#fff1be] from-28% via-[#ee87cb] via-70% to-[#b060ff] bg-clip-text text-transparent">
                    Retired Teacher, Ontario
                  </span>
                </p>
              </figcaption>
            </figure>
          </div>
        </div>
      </Container>
    </div>
    <Container>
      <section id="faqs" class="scroll-mt-8">
        <Subheading class="text-center">Frequently asked questions</Subheading>
        <Heading as="div" class="mt-2 text-center">Your questions answered.</Heading>
        <div class="mx-auto mt-16 mb-32 max-w-xl space-y-12">
          <dl>
            <dt class="text-sm font-semibold">How does Slackwater calculate my retirement projections?</dt>
            <dd class="mt-4 text-sm/6 text-gray-600">
              Slackwater uses your current income, savings rate, investment
              balances, and expected returns to project when you can retire and
              how much annual income you'll have. As you update your balances
              over time, your projections become more and more accurate.
            </dd>
          </dl>
          <dl>
            <dt class="text-sm font-semibold">What's the difference between the withdrawal strategies on each plan?</dt>
            <dd class="mt-4 text-sm/6 text-gray-600">
              The Starter plan uses standard withdrawal strategies. The Pro plan
              unlocks advanced strategies like variable percentage withdrawal and
              guardrails-based approaches that can significantly reduce your tax
              burden — potentially saving around $200K over your retirement. The
              Smart plan uses a fully optimized, personalized withdrawal sequence
              that could save $500K to $1M or more in lifetime taxes.
            </dd>
          </dl>
          <dl>
            <dt class="text-sm font-semibold">Is there a mobile app available?</dt>
            <dd class="mt-4 text-sm/6 text-gray-600">
              Yes, Slackwater has a mobile app and an Apple Watch app with
              complications so you can check your retirement plan at a glance.
              Widgets and the Watch app are available on the Pro and Smart plans.
            </dd>
          </dl>
          <dl>
            <dt class="text-sm font-semibold">How does the retirement paycheque view work?</dt>
            <dd class="mt-4 text-sm/6 text-gray-600">
              Once you enter retirement mode, your dashboard transforms into a
              paycheque-style view. It tells you exactly which accounts to pull
              from each month, how much to withdraw, and adjusts automatically
              based on market performance to keep you on track.
            </dd>
          </dl>
          <dl>
            <dt class="text-sm font-semibold">Is my financial data secure?</dt>
            <dd class="mt-4 text-sm/6 text-gray-600">
              Absolutely. Your data is encrypted at rest and in transit. We never
              sell your data or share it with third parties. Slackwater is a
              planning tool — we don't connect to your bank accounts or have
              access to your money.
            </dd>
          </dl>
        </div>
      </section>
    </Container>
    <Footer />
  </main>
</BaseLayout>
