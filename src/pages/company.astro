---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import GradientBackground from '@/components/GradientBackground.astro'
import Heading from '@/components/Heading.astro'
import Subheading from '@/components/Subheading.astro'
import Lead from '@/components/Lead.astro'
import Button from '@/components/Button.astro'
import Footer from '@/components/Footer.astro'
import { Navbar } from '@/components/react/Navbar'
import { AnimatedNumber } from '@/components/react/AnimatedNumber'
---
<BaseLayout title="Company" description="Slackwater is on a mission to help Canadians retire with confidence by providing smart, tax-optimized retirement planning tools.">
  <main class="overflow-hidden">
    <GradientBackground />
    <Container>
      <Navbar client:load />
    </Container>
    <Container class="mt-16">
      <Heading as="h1">Helping Canadians retire with confidence.</Heading>
      <Lead class="mt-6 max-w-3xl">
        We're on a mission to make retirement planning accessible, intelligent,
        and genuinely life-changing for every Canadian.
      </Lead>
      <section class="mt-16 grid grid-cols-1 lg:grid-cols-2 lg:gap-12">
        <div class="max-w-lg">
          <h2 class="text-2xl font-medium tracking-tight">Our mission</h2>
          <p class="mt-6 text-sm/6 text-gray-600">
            At Slackwater, we believe everyone deserves a clear, confident path
            to retirement. Our mission is to take the complexity out of
            retirement planning and put the power of tax optimization into the
            hands of everyday Canadians. We build tools that turn financial
            uncertainty into clarity.
          </p>
          <p class="mt-8 text-sm/6 text-gray-600">
            We're obsessed with helping you keep more of what you've earned.
            Retirement planning shouldn't require a financial advisor charging
            thousands of dollars. Slackwater gives you the same level of
            tax-optimized withdrawal planning that high-net-worth clients get,
            at a fraction of the cost.
          </p>
        </div>
        <div class="pt-20 lg:row-span-2 lg:-mr-16 xl:mr-auto">
          <div class="-mx-8 grid grid-cols-2 gap-4 sm:-mx-16 sm:grid-cols-4 lg:mx-0 lg:grid-cols-2 lg:gap-4 xl:gap-8">
            <div class="aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10">
              <img alt="" src="/company/1.jpg" class="block size-full object-cover" />
            </div>
            <div class="-mt-8 aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10 lg:-mt-32">
              <img alt="" src="/company/2.jpg" class="block size-full object-cover" />
            </div>
            <div class="aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10">
              <img alt="" src="/company/3.jpg" class="block size-full object-cover" />
            </div>
            <div class="-mt-8 aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10 lg:-mt-32">
              <img alt="" src="/company/4.jpg" class="block size-full object-cover" />
            </div>
          </div>
        </div>
        <div class="max-lg:mt-16 lg:col-span-1">
          <Subheading>The Numbers</Subheading>
          <hr class="mt-6 border-t border-gray-200" />
          <dl class="mt-6 grid grid-cols-1 gap-x-8 gap-y-4 sm:grid-cols-2">
            <div class="flex flex-col gap-y-2 border-b border-dotted border-gray-200 pb-4">
              <dt class="text-sm/6 text-gray-600">Tax Savings Delivered</dt>
              <dd class="order-first text-6xl font-medium tracking-tight">
                $<AnimatedNumber client:visible start={50} end={100} />M+
              </dd>
            </div>
            <div class="flex flex-col gap-y-2 border-b border-dotted border-gray-200 pb-4">
              <dt class="text-sm/6 text-gray-600">Canadians Planning</dt>
              <dd class="order-first text-6xl font-medium tracking-tight">
                <AnimatedNumber client:visible start={5} end={10} />K+
              </dd>
            </div>
            <div class="flex flex-col gap-y-2 max-sm:border-b max-sm:border-dotted max-sm:border-gray-200 max-sm:pb-4">
              <dt class="text-sm/6 text-gray-600">Retirement Plans Created</dt>
              <dd class="order-first text-6xl font-medium tracking-tight">
                <AnimatedNumber client:visible start={10} end={25} />K
              </dd>
            </div>
            <div class="flex flex-col gap-y-2">
              <dt class="text-sm/6 text-gray-600">Projections Run</dt>
              <dd class="order-first text-6xl font-medium tracking-tight">
                <AnimatedNumber client:visible start={50} end={100} />K+
              </dd>
            </div>
          </dl>
        </div>
      </section>
    </Container>
    <Container class="mt-32">
      <Subheading>Meet the team</Subheading>
      <Heading as="h3" class="mt-2">Founded by people who believe in better retirement planning.</Heading>
      <Lead class="mt-6 max-w-3xl">
        Slackwater was founded by a team passionate about making retirement
        planning smarter, simpler, and more accessible for everyone.
      </Lead>
      <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div class="max-w-lg">
          <p class="text-sm/6 text-gray-600">
            Slackwater started with a simple observation: most retirement
            planning tools tell you if you have enough saved, but none of them
            tell you how to actually spend it in the most tax-efficient way. The
            difference between a good withdrawal strategy and a great one can be
            hundreds of thousands of dollars over a retirement.
          </p>
          <p class="mt-8 text-sm/6 text-gray-600">
            Today, Slackwater helps thousands of Canadians plan their retirement
            with confidence. Whether you're ten years out or already retired, our
            platform builds a personalized plan that adapts to your life and the
            markets, so you can focus on living instead of worrying.
          </p>
          <div class="mt-6">
            <Button class="w-full sm:w-auto" href="#">Join us</Button>
          </div>
        </div>
        <div class="max-lg:order-first max-lg:max-w-lg">
          <div class="aspect-3/2 overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10">
            <img alt="" src="/company/5.jpg" class="block size-full object-cover" />
          </div>
        </div>
      </div>
      <Subheading as="h3" class="mt-24">The team</Subheading>
      <hr class="mt-6 border-t border-gray-200" />
      <ul role="list" class="mx-auto mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { name: 'Michael Foster', description: 'Co-Founder / CTO', img: '/team/michael-foster.jpg' },
          { name: 'Dries Vincent', description: 'Business Relations', img: '/team/dries-vincent.jpg' },
          { name: 'Celeste Vandermark', description: 'Front-end Developer', img: '/team/celeste-vandermark.jpg' },
          { name: 'Courtney Henry', description: 'Designer', img: '/team/courtney-henry.jpg' },
          { name: 'Marcus Eldridge', description: 'Director of Product', img: '/team/marcus-eldridge.jpg' },
          { name: 'Whitney Francis', description: 'Copywriter', img: '/team/whitney-francis.jpg' },
          { name: 'Leonard Krasner', description: 'Senior Designer', img: '/team/leonard-krasner.jpg' },
          { name: 'Nolan Sheffield', description: 'Principal Designer', img: '/team/nolan-sheffield.jpg' },
          { name: 'Emily Selman', description: 'VP, User Experience', img: '/team/emily-selman.jpg' },
        ].map((person) => (
          <li class="flex items-center gap-4">
            <img alt="" src={person.img} class="size-12 rounded-full" />
            <div class="text-sm/6">
              <h3 class="font-medium">{person.name}</h3>
              <p class="text-gray-500">{person.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </Container>
    <Container class="mt-32">
      <Subheading>Funding</Subheading>
      <Heading as="h3" class="mt-2">Independently built.</Heading>
      <Lead class="mt-6 max-w-3xl">
        Slackwater is proudly bootstrapped and independently funded. We answer
        to our users, not investors.
      </Lead>
    </Container>
    <Container class="my-32">
      <Subheading>Careers</Subheading>
      <Heading as="h3" class="mt-2">Join our fully remote team.</Heading>
      <Lead class="mt-6 max-w-3xl">
        We work together from across Canada, building the future of retirement
        planning.
      </Lead>
      <div class="mt-24 grid grid-cols-1 gap-16 lg:grid-cols-[1fr_24rem]">
        <div class="lg:max-w-2xl">
          <Subheading as="h3">Open positions</Subheading>
          <div>
            <table class="w-full text-left">
              <colgroup>
                <col class="w-2/3" />
                <col class="w-1/3" />
                <col class="w-0" />
              </colgroup>
              <thead class="sr-only">
                <tr>
                  <th scope="col">Title</th>
                  <th scope="col">Location</th>
                  <th scope="col">Read more</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <th scope="colgroup" colspan="3" class="px-0 pt-10 pb-0">
                    <div class="-mx-4 rounded-lg bg-gray-50 px-4 py-3 text-sm/6 font-semibold">Engineering</div>
                  </th>
                </tr>
                <tr class="border-b border-dotted border-gray-200 text-sm/6 font-normal">
                  <td class="px-0 py-4">iOS Developer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
                <tr class="border-b border-dotted border-gray-200 text-sm/6 font-normal">
                  <td class="px-0 py-4">Backend Engineer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
                <tr class="text-sm/6 font-normal">
                  <td class="px-0 py-4">Product Engineer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
                <tr>
                  <th scope="colgroup" colspan="3" class="px-0 pt-5 pb-0">
                    <div class="-mx-4 rounded-lg bg-gray-50 px-4 py-3 text-sm/6 font-semibold">Design</div>
                  </th>
                </tr>
                <tr class="border-b border-dotted border-gray-200 text-sm/6 font-normal">
                  <td class="px-0 py-4">Principal Designer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
                <tr class="border-b border-dotted border-gray-200 text-sm/6 font-normal">
                  <td class="px-0 py-4">Designer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
                <tr class="text-sm/6 font-normal">
                  <td class="px-0 py-4">Senior Designer</td>
                  <td class="px-0 py-4 text-gray-600">Remote</td>
                  <td class="px-0 py-4 text-right"><Button variant="outline" href="#">View listing</Button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="relative flex aspect-square flex-col justify-end overflow-hidden rounded-3xl sm:aspect-5/4 lg:aspect-3/4">
          <img alt="" src="/testimonials/veronica-winton.jpg" class="absolute inset-0 object-cover" />
          <div aria-hidden="true" class="absolute inset-0 rounded-3xl bg-linear-to-t from-black from-10% to-75% ring-1 ring-gray-950/10 ring-inset lg:from-25%" />
          <figure class="relative p-10">
            <blockquote>
              <p class="relative text-xl/7 text-white before:absolute before:-translate-x-full before:content-['\201C'] after:absolute after:content-['\201D']">
                Working at Slackwater means helping real people retire with confidence. There&apos;s nothing more rewarding.
              </p>
            </blockquote>
            <figcaption class="mt-6 border-t border-white/20 pt-6">
              <p class="text-sm/6 font-medium text-white">Emily Selman</p>
              <p class="text-sm/6 font-medium">
                <span class="bg-linear-to-r from-[#b8f0e6] from-28% via-[#5bb8d4] via-70% to-[#1a6b8a] bg-clip-text text-transparent">
                  VP, User Experience
                </span>
              </p>
            </figcaption>
          </figure>
        </div>
      </div>
    </Container>
    <Footer />
  </main>
</BaseLayout>
